# ─────────────────────────────────────────────────────────────────────────────
# SkillOS -- Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your real values.
# Run: python scripts/validate_setup.py  to verify everything is set up correctly.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SKILLOS_SECRET_KEY=change-this-to-a-32-character-random-string
SKILLOS_ENV=development

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Leave empty -> SQLite (dev only, auto-created)
# Set this for production -> PostgreSQL (free at neon.tech)
DATABASE_URL=
# Example: DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/skillos

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Leave empty -> threading mode (dev)
# Set for production job queue (free at upstash.com)
REDIS_URL=
# Example: REDIS_URL=redis://default:password@us1-xxx.upstash.io:6379

# ─────────────────────────────────────────────────────────────────────────────
# ── AI PROVIDERS -- Multi-Key Support ────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# The system automatically tries providers in order: Groq -> Gemini -> Anthropic -> OpenAI
# If all AI providers fail, falls back to rule-based analysis (always works).
#
# MULTI-KEY: You can provide multiple keys per provider (comma-separated).
# Keys are used in round-robin rotation. Failed/rate-limited keys are
# automatically skipped and retried after a cooldown period.
#
#   Single key:  GROQ_API_KEY=gsk_abc123
#   Multi-key:   GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3
#
# Check which providers are active (after login):
#   GET http://localhost:8000/admin/ai-status

# Groq -- FASTEST, FREE tier
# Get at: https://console.groq.com
# Model: llama-3.3-70b-versatile (~50ms, very generous free tier)
GROQ_API_KEY=

# Google Gemini -- FAST, 1500 free req/day
# Get at: https://aistudio.google.com/app/apikey
# Model: gemini-2.0-flash (~200ms)
GEMINI_API_KEY=

# Anthropic Claude -- BEST code reasoning
# Get at: https://console.anthropic.com
# Model: claude-haiku-4-5 (~400ms, ~$0.001/review)
ANTHROPIC_API_KEY=

# OpenAI -- Reliable fallback
# Get at: https://platform.openai.com/api-keys
# Model: gpt-4o-mini (~500ms, ~$0.002/review)
OPENAI_API_KEY=

# Optional: override provider order
# AI_PROVIDER_ORDER=groq,gemini,anthropic,openai

# Optional: disable specific providers
# AI_DISABLE_PROVIDERS=openai

# Optional: key health settings
# AI_KEY_COOLDOWN_SECONDS=60      # cooldown after key failure
# AI_RATE_LIMIT_COOLDOWN_SECONDS=120  # cooldown after 429 rate-limit
# AI_KEY_MAX_FAILURES=3           # failures before key is suspended

# ─────────────────────────────────────────────────────────────────────────────
# ── CODE EXECUTION SANDBOX ───────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# auto   = use Docker if available, subprocess fallback otherwise (default)
# true   = force Docker (requires Docker daemon to be running)
# false  = force subprocess (safe for dev, NOT for production)
#
# Docker sandbox gives: filesystem isolation, network disabled,
# CPU + memory hard limits, PID limits, no privilege escalation.
#
# Check sandbox mode (after login):
#   GET http://localhost:8000/admin/sandbox-status
SKILLOS_USE_DOCKER=auto

# Docker resource limits (only used when SKILLOS_USE_DOCKER=true)
DOCKER_MEMORY_LIMIT=256m
DOCKER_CPU_LIMIT=0.5

# Pre-warm Docker images at startup (pull language images in background)
# This eliminates cold-start latency on first submission
SANDBOX_PREWARM=true

# ── GITHUB ────────────────────────────────────────────────────────────────────
# Raises API rate limit from 60 -> 5000 req/hr
# Create at: https://github.com/settings/tokens (select: public_repo)
GITHUB_TOKEN=

# ── PAYMENTS (Razorpay) ───────────────────────────────────────────────────────
# Test keys from: https://dashboard.razorpay.com -> Settings -> API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── EMAIL (Gmail SMTP) ────────────────────────────────────────────────────────
# Gmail -> Google Account -> Security -> App passwords -> Create
SMTP_USER=your-email@gmail.com
SMTP_PASS=

# ── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com -> APIs -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=

# ── APP URLS ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
